# =============================================================================
# TCPA / FCC Opt-Out Integration Layer — Environment Configuration
# Copy this file to `.env` and fill in real values before deploying.
# =============================================================================

# ---------- Runtime ----------
ENVIRONMENT=development
LOG_FORMAT=console
REQUIRE_STRICT_SECRETS=true
WORKER_ENABLED=true

# ---------- HTTP / CORS ----------
# Comma-separated allowlist for browser origins. Production must NOT be "*".
ALLOWED_ORIGINS=https://dashboard.yourdomain.com,https://admin.yourdomain.com

# ---------- Database ----------
DATABASE_URL=sqlite+aiosqlite:///./data/data.db
SQLITE_WAL_MODE=true

# ---------- Auth / Secrets ----------
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_API_KEY=replace-me-with-token-urlsafe-48
TWILIO_AUTH_TOKEN=replace-me-with-real-twilio-token

# ---------- Background worker ----------
WORKER_POLL_INTERVAL=5
MAX_RETRIES=5
BACKOFF_FACTOR=2

# ---------- Google Gemini (intent classifier) ----------
# Set to "mock" for offline rule-based fallback.
GEMINI_API_KEY=mock
GEMINI_API_BASE_URL=
GEMINI_MODEL=gemini-1.5-flash

# ---------- Downstream CRM credentials ----------
HUBSPOT_ACCESS_TOKEN=hubspot_mock_token
SALESFORCE_INSTANCE_URL=https://mock.salesforce.com
SALESFORCE_ACCESS_TOKEN=salesforce_mock_token
GOHIGHLEVEL_ACCESS_TOKEN=gohighlevel_mock_token
GOHIGHLEVEL_LOCATION_ID=mock_location_123
